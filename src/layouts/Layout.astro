---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
}

const {
  title = 'パルバル湘南スポーツクラブ',
  description = '茅ヶ崎のフィットネス、キッズ水泳・ダンス。バリューフィットネスでクオリティライフを。',
  bodyClass = '',
} = Astro.props;
---

<!doctype html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title === 'パルバル湘南スポーツクラブ' ? title : `${title} | パルバル湘南スポーツクラブ`}</title>
  <link rel="icon" type="image/x-icon" href="https://pal-ball.com/wp-content/themes/pal-ball/assets/common_img/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=M+PLUS+1p:wght@400;500;700;800;900&display=swap" rel="stylesheet" />
</head>
<body class={bodyClass}>
<div id="wrapper">

  <!-- cm-header -->
  <header id="cm-header" class="header">
    <div class="header-inner">
      <div class="header-inner__logo">
        <a href="/" class="ov-hover">
          <img src="/images/common/img_0.webp" alt="パルバル湘南スポーツクラブ" width="192" height="192" />
        </a>
      </div>
      <div class="header-inner__right">
        <nav id="menuContents" class="l-menu_contents">
          <ul class="gnav">
            <li class="gnav__item">
              <a href="/concept/" class="gnav__link nav-link cm-arr cm-arr--right">コンセプト</a>
            </li>
            <li class="gnav__item">
              <a href="/guide/" class="gnav__link nav-link cm-arr cm-arr--right">料金 / 入会案内</a>
            </li>
            <li class="gnav__item">
              <a href="/fitness/" class="gnav__link nav-link cm-arr cm-arr--right">フィットネス</a>
            </li>
            <li class="gnav__item">
              <a href="/personal/" class="gnav__link nav-link cm-arr cm-arr--right">パーソナルトレーニング</a>
            </li>
            <li class="gnav__item">
              <a href="/kids_swimming/" class="gnav__link nav-link cm-arr cm-arr--right">キッズスイミング</a>
            </li>
            <li class="gnav__item">
              <a href="/kids_dance/" class="gnav__link nav-link cm-arr cm-arr--right">キッズダンス</a>
            </li>
            <li class="gnav__item">
              <a href="/facility/" class="gnav__link nav-link cm-arr cm-arr--right">施設紹介</a>
            </li>
            <li class="gnav__item">
              <a href="/contact/#faq" class="gnav__link nav-link cm-arr cm-arr--right">よくある質問</a>
            </li>
          </ul>
        </nav>
        <div class="h-btn">
          <ul class="list-btn-side">
            <li class="list-btn-side__item">
              <a href="https://www4.e-atoms.jp/HAYASHIWebUser/PreReserv/index?TmpCd=003&SMBC=1" target="_blank" rel="noopener" class="list-btn-side__link btn-WEB btn-hover">
                <span class="list-btn-side__icon">
                  <img src="/images/common/img_1.webp" alt="icon-WEB" width="40" height="45" />
                </span>
                <span class="list-btn-side__txt">フィットネス<br />WEB入会</span>
              </a>
            </li>
            <li class="list-btn-side__item">
              <a href="https://scr.buscatch.net/trial/list?f=pal-ball" target="_blank" rel="noopener" class="list-btn-side__link btn-school btn-hover">
                <span class="list-btn-side__icon">
                  <img src="/images/common/img_2.webp" alt="icon-school" width="54" height="32" />
                </span>
                <span class="list-btn-side__txt">キッズスクール<br />体験申し込み</span>
              </a>
            </li>
          </ul>
        </div>
        <!-- モバイル用ハンバーガーメニュー（768px以下で表示） -->
        <button class="hamburger-menu show-mobile" id="hamburgerMenu" aria-label="メニュー">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
        <!-- 既存のMENUボタン（1500px以上で表示） -->
        <a class="trigger-menu show-from-1500" id="triggerMenu">
          <p class="icon">
            <span></span>
            <span></span>
            <span></span>
          </p>
          <p class="txt">MENU</p>
        </a>
      </div>
    </div>
  </header>

  <!-- cm-main (pages provide their own <main id="cm-main"> wrapper) -->
  <slot />

  <!-- cm-footer -->
  <footer id="cm-footer">
    <section class="sec-infor">
      <div class="sec-infor__main-infor">
        <p class="txt-eng">sports<br />club</p>
        <div class="inner-infor">
          <h2 class="sec-infor__ttl">店舗情報</h2>
          <div class="inner-infor__head">
            <p class="inner-infor__logo">
              <img src="/images/common/img_0.webp" alt="PAL-BALL SPORTSCLUB" width="192" height="192" />
            </p>
            <p class="inner-infor__txt">パルバル湘南スポーツクラブ<span>周辺地域：茅ヶ崎 / 辻堂 / 藤沢 / 平塚 / 湘南</span></p>
          </div>
          <table class="style-table01">
            <tbody>
              <tr>
                <th>住所</th>
                <td>
                  <p>〒253-0042　<br class="show-sp" />神奈川県茅ヶ崎市本村1丁目4-20</p>
                  <p class="img-map mt20">
                    <img src="/images/common/img_8.webp" alt="infor-map" width="384" height="216" />
                  </p>
                </td>
              </tr>
              <tr>
                <th>アクセス</th>
                <td>
                  <h3 class="txt-yellow">電車でお越しの場合</h3>
                  <p>JR東海道線「茅ヶ崎駅」北口下車、徒歩15分</p>
                  <h3 class="txt-yellow mt15">バスでお越しの場合</h3>
                  <p>JR東海道線「茅ヶ崎駅」北口から<br />神奈中バス「藤沢駅北口」行きに乗車、「本村」下車徒歩1分</p>
                  <h3 class="txt-yellow mt15">車をご利用の場合</h3>
                  <p>国道1号線「本村」交差点沿い<br />一中通りを国道1号線方面に進み、「本村」交差点沿い</p>
                  <p class="mt10">※無料駐車場80台分完備</p>
                </td>
              </tr>
              <tr>
                <th>電話番号</th>
                <td>
                  <a href="tel:0467-54-4411">0467-54-4411</a>
                </td>
              </tr>
              <tr>
                <th>営業時間</th>
                <td>
                  <div class="list-time">
                    <div class="list-time__item">
                      <p class="list-time__day w-set">月～金曜日：</p>
                      <p class="list-time__time">
                        <span class="time">9:00 ～ 22:00</span>　<br class="show-sp" />※水曜日を除く
                      </p>
                    </div>
                    <div class="list-time__item">
                      <p class="list-time__day w-set">土曜日：</p>
                      <p class="list-time__time">
                        <span class="time">9:00 ～ 20:00</span>
                      </p>
                    </div>
                    <div class="list-time__item">
                      <p class="list-time__day w-set">日曜・祝日：</p>
                      <p class="list-time__time">
                        <span class="time">9:00 ～ 19:00</span>
                      </p>
                    </div>
                  </div>
                </td>
              </tr>
              <tr>
                <th>休館日</th>
                <td>
                  <div class="list-time">
                    <p>水曜日（定休日）※水曜日はキッズスクールのみ営業</p>
                    <div class="list-time__item">
                      <p class="list-time__day">夏季休業：</p>
                      <p class="list-time__time">8/12 ～ 8/16</p>
                    </div>
                    <div class="list-time__item">
                      <p class="list-time__day">年末年始：</p>
                      <p class="list-time__time">12/28 ～ 1/3</p>
                    </div>
                  </div>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
      <div class="sec-infor__map">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3254.7877268760244!2d139.41464829999998!3d35.336092400000005!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x60185265a32bf6bb%3A0x3c2e0ebf61423250!2z44OR44Or44OQ44Or5rmY5Y2X44K544Od44O844OE44Kv44Op44OW!5e0!3m2!1sja!2s!4v1735918033215!5m2!1sja!2s" width="600" height="450" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </section>
    <div class="sec-contact">
      <div class="container">
        <p class="text-center">
          <a href="/contact/" class="cm-btn cm-btn--btn-black btn-hover">お問い合わせ</a>
        </p>
        <ul class="list-socal">
          <li>
            <a href="https://www.facebook.com/profile.php?id=61572886543186" target="_blank" rel="noopener" class="list-socal__link">
              <p><img src="/images/common/img_9.webp" alt="facebook Fitness" width="40" height="40" /></p>
              <p class="list-socal__txt">Facebook<br />Fitness</p>
            </a>
          </li>
          <li>
            <a href="https://www.facebook.com/profile.php?id=100023398066847" target="_blank" rel="noopener" class="list-socal__link">
              <p><img src="/images/common/img_9.webp" alt="facebook Kids School" width="40" height="40" /></p>
              <p class="list-socal__txt">Facebook<br />Kids School</p>
            </a>
          </li>
          <li>
            <a href="https://www.instagram.com/palball_fitness/" target="_blank" rel="noopener" class="list-socal__link">
              <p><img src="/images/common/img_10.webp" alt="Instagram Fitness" width="40" height="40" /></p>
              <p class="list-socal__txt">Instagram<br />Fitness</p>
            </a>
          </li>
          <li>
            <a href="https://www.instagram.com/palball_shonan_sportsclub/" target="_blank" rel="noopener" class="list-socal__link">
              <p><img src="/images/common/img_10.webp" alt="Instagram Kids School" width="40" height="40" /></p>
              <p class="list-socal__txt">Instagram<br />Kids School</p>
            </a>
          </li>
        </ul>
      </div>
    </div>
    <div class="f-gnav">
      <div class="container">
        <ul class="f-gnav__list">
          <li class="f-gnav__item"><a href="/" class="f-gnav__link nav-link">HOME</a></li>
          <li class="f-gnav__item"><a href="/concept/" class="f-gnav__link nav-link">コンセプト</a></li>
          <li class="f-gnav__item"><a href="/guide/" class="f-gnav__link nav-link">料金 / 入会案内</a></li>
          <li class="f-gnav__item"><a href="/fitness/" class="f-gnav__link nav-link">フィットネス</a></li>
          <li class="f-gnav__item"><a href="/personal/" class="f-gnav__link nav-link">パーソナルトレーニング</a></li>
          <li class="f-gnav__item"><a href="/kids_swimming/" class="f-gnav__link nav-link">キッズスイミング</a></li>
          <li class="f-gnav__item"><a href="/kids_dance/" class="f-gnav__link nav-link">キッズダンス</a></li>
          <li class="f-gnav__item"><a href="/facility/" class="f-gnav__link nav-link">施設紹介</a></li>
          <li class="f-gnav__item"><a href="/contact/#faq" class="f-gnav__link nav-link">よくある質問</a></li>
          <li class="f-gnav__item"><a href="/topics/" class="f-gnav__link nav-link">お知らせ</a></li>
          <li class="f-gnav__item"><a href="/company/" class="f-gnav__link nav-link">会社案内</a></li>
          <li class="f-gnav__item"><a href="/recruitment/" class="f-gnav__link nav-link">採用情報</a></li>
          <li class="f-gnav__item"><a href="/contact/" class="f-gnav__link nav-link">お問い合わせ</a></li>
          <li class="f-gnav__item"><a href="/contact/#pp" class="f-gnav__link nav-link">プライバシーポリシー</a></li>
        </ul>
      </div>
    </div>
    <p class="copyright">
      <span>© 2025 pal-ball shonan sportsclub.</span>
    </p>
    <div id="page-up" style="display: none; position: fixed; bottom: 50px; right: 1%;">
      <a href="#wrapper" aria-label="Back to top" class="cm-arr"></a>
    </div>
  </footer>

</div><!-- /#wrapper -->

<script>
// ハンバーガーメニュー（モバイル用）
const hamburger = document.getElementById('hamburgerMenu');
const menuContents = document.getElementById('menuContents');
const body = document.body;

if (hamburger) {
  hamburger.addEventListener('click', () => {
    hamburger.classList.toggle('is-active');
    menuContents.classList.toggle('is-visible');
    body.classList.toggle('is-mobile-menu-open');
  });
}

// 既存のMENUボタン（1500px以上）
const trigger = document.getElementById('triggerMenu');

if (trigger) {
  trigger.addEventListener('click', () => {
    trigger.classList.toggle('is-active');
    body.classList.toggle('is-menu-open');
  });
}

// ヘッダースクロール固定
const header = document.getElementById('cm-header');
window.addEventListener('scroll', () => {
  if (window.scrollY > 50) {
    header?.classList.add('fixed');
  } else {
    header?.classList.remove('fixed');
  }
});

// ページトップボタン
const pageUp = document.getElementById('page-up');
window.addEventListener('scroll', () => {
  if (pageUp) {
    pageUp.style.display = window.scrollY > 200 ? 'block' : 'none';
  }
});
</script>
</body>
</html>
