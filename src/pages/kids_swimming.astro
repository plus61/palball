                <div class="page-index">
                    <p class="page-index__ttl">page index</p>
                    <ul class="page-index__anchor-link anchor-link">
                        <li class="anchor-link__item">
                            <a href="#point" class="anchor-link__link cm-arr cm-arr--down">
                                <span>特徴</span>
                            </a>
                        </li>
                        <li class="anchor-link__item">
                            <a href="#reason" class="anchor-link__link cm-arr cm-arr--down">
                                <span>選ばれる理由</span>
                            </a>
                        </li>
                        <li class="anchor-link__item">
                            <a href="#supervisor" class="anchor-link__link cm-arr cm-arr--down">
                                <span>監修者紹介</span>
                            </a>
                        </li>
                        <li class="anchor-link__item">
                            <a href="#class" class="anchor-link__link cm-arr cm-arr--down">
                                <span>クラス紹介</span>
                            </a>
                        </li>
                        <li class="anchor-link__item">
                            <a href="#lecturer" class="anchor-link__link cm-arr cm-arr--down">
                                <span>講師紹介</span>
                            </a>
                        </li>
                        <li class="anchor-link__item">
                            <a href="#price_system" class="anchor-link__link cm-arr cm-arr--down">
                                <span>料金・制度案内</span>
                            </a>
                        </li>
                        <li class="anchor-link__item">
                            <a href="#voice" class="anchor-link__link cm-arr cm-arr--down">
